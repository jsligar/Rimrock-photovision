NAS_SOURCE_DIR=/mnt/mycloud/photos
LOCAL_BASE=/local/rimrock/photos
API_PORT=8420

# NVIDIA Burst Intelligence (Phase 4) — OFF by default
# Set NVIDIA_BURST_ENABLED=true and NVIDIA_API_KEY to activate.
# NVIDIA_BURST_ENABLED=false
# NVIDIA_API_KEY=nvapi-xxxx
# NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_LLM_MODEL=meta/llama-3.1-70b-instruct
# NVIDIA_VISION_MODEL=microsoft/phi-3.5-vision-instruct
# NVIDIA_BURST_DAILY_REQUEST_CAP=100
# NVIDIA_BURST_DAILY_TOKEN_CAP=50000
# NVIDIA_BURST_PRIVACY_MODE=true
# NVIDIA_BURST_CACHE_ENABLED=true
# NVIDIA_BURST_QUERY_REWRITE=true
# Reranking requires a separate NVIDIA model not yet available on trial keys:
# NVIDIA_BURST_RERANK=false
# NVIDIA_RERANK_MODEL=nvidia/nv-rerankqa-mistral-4b-v3
